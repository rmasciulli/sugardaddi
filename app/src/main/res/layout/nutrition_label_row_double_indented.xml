<?xml version="1.0" encoding="utf-8"?>
<!-- nutrition_label_row_double_indented.xml - Double-indented nutrient row (level 2) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Row Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:gravity="center_vertical"
        android:minHeight="28dp">

        <!-- Column 1: Nutrient Name (double-indented via paddingStart on TextView) -->
        <TextView
            android:id="@+id/nutrientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textSize="12sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingStart="32dp"
            android:paddingEnd="8dp"
            android:text="    DHA"/>

        <!-- Column 2: Per 100g Value (aligned with standard row) -->
        <TextView
            android:id="@+id/valuePer100g"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeStepGranularity="1sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="end"
            android:paddingEnd="8dp"
            android:text="0 mg"/>

        <!-- Column 3: Custom Amount Value (aligned with standard row) -->
        <TextView
            android:id="@+id/valueCustomAmount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="10sp"
            android:autoSizeMaxTextSize="12sp"
            android:autoSizeStepGranularity="1sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="end"
            android:text="0 mg"/>

    </LinearLayout>

    <!-- Divider under row -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/colorOnSurface"
        android:alpha="0.1"/>

</LinearLayout>