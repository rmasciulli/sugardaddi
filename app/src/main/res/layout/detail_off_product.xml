<?xml version="1.0" encoding="utf-8"?>
<!--
    detail_off_product.xml - Detail layout for OpenFoodFacts products. (v3)

    STRUCTURE:
      1. Hero image - full-width, no card
      2. Main content card - one single card containing:
           a. Product info: name, brand, quantity, category
           b. Score strip: Nutri-Score | Green-Score | Nova (left-aligned, 48dp)
           c. Allergens section (conditional - hidden when allergenFlags == 0)
           d. Nutrition Facts section
      3. Attribution card - amber, separate, tappable (genuinely different nature)

    DESIGN RATIONALE (v3):
    One content card with internal section dividers replaces the previous 3 separate
    content cards. Sections are separated by 1dp colorOutlineVariant dividers and
    compact textAppearanceLabelMedium headers - not Headline6 bold titles, which
    were oversized relative to the content density.

    Score stickers are left-aligned with paddingStart="12dp" at 48dp height.
    No equal-weight columns - each sticker takes wrap_content width.
    This keeps the strip compact and avoids the 3-column grid structure
    which was spreading stickers unnecessarily across the full card width.

    The allergen divider + header are hidden together with the icon container
    when allergenFlags == 0 (controlled by OffProductDetailRenderer).

    Attribution remains a separate card because:
      - It has a distinct amber background color
      - It is tappable (opens an external URL)
      - It is meta/legal content, not product content

    SCORE CONTAINER SIZING:
    Fixed 48dp height on all sticker views. wrap_content width + adjustViewBounds
    so aspect ratio drives width. No layout_weight - stickers are left-aligned,
    not spread across the row.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ======================================================= -->
        <!-- 1. HERO IMAGE                                           -->
        <!-- ======================================================= -->
        <ImageView
            android:id="@+id/heroImage"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="?attr/colorSurfaceVariant"
            android:contentDescription="@string/product_image_description"
            android:scaleType="centerCrop"
            tools:src="@drawable/ic_food_placeholder" />

        <!-- ======================================================= -->
        <!-- 2. MAIN CONTENT CARD                                    -->
        <!--    Single card, multiple sections separated by dividers -->
        <!-- ======================================================= -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ~ -->
                <!-- 2a. PRODUCT INFO                        -->
                <!-- ~ -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/productName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        tools:text="Fourres chocolat noir" />

                    <TextView
                        android:id="@+id/brandName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorPrimary"
                        android:visibility="gone"
                        tools:text="Bjorg"
                        tools:visibility="visible" />

                    <!-- Quantity and category on same line when both present,
                         otherwise each on their own line. Both use Body2 / secondary color. -->
                    <TextView
                        android:id="@+id/quantityText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="225 g"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/categoryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="Snacks"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- ~ -->
                <!-- 2b. SCORE STRIP                         -->
                <!--     Left-aligned, 48dp height, compact  -->
                <!--     Hidden by default, shown by renderer -->
                <!-- ~ -->
                <LinearLayout
                    android:id="@+id/scoresRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp"
                    android:visibility="gone">

                    <!--
                        Nutri-Score programmatic container.
                        Renderer adds sticker as MATCH_PARENT height child.
                        Fixed 48dp height, wrap_content width.
                    -->
                    <FrameLayout
                        android:id="@+id/nutriScoreStickerContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center_vertical" />

                    <!-- Spacing between Nutri-Score and Green-Score -->
                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <!--
                        Green-Score horizontal sticker.
                        Renderer sets drawable via setImageResource().
                        Fixed 48dp height, adjustViewBounds scales width from aspect ratio.
                    -->
                    <ImageView
                        android:id="@+id/greenScoreSticker"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/content_description_green_score"
                        tools:src="@drawable/greenscore_horizontal_b" />

                    <!-- Spacing between Green-Score and Nova -->
                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <!--
                        Nova Group badge. Hidden (GONE) when novaGroup is null/unknown.
                        Renderer shows novaGroupUnavailable TextView instead when no data.
                        Fixed 48dp height, square badge scales to ~48x48dp.
                    -->
                    <ImageView
                        android:id="@+id/novaGroupBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/nova_group_content_description"
                        android:visibility="gone"
                        tools:src="@drawable/novagroup_4"
                        tools:visibility="visible" />

                    <!--
                        Shown when Nova data is absent.
                        Same height as badge for consistent strip height.
                    -->
                    <TextView
                        android:id="@+id/novaGroupUnavailable"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:text="@string/score_unavailable"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone" />

                </LinearLayout>

                <!-- ~ -->
                <!-- 2c. ALLERGENS SECTION (conditional)     -->
                <!--     Divider + header + icon grid        -->
                <!--     All three toggled together by       -->
                <!--     renderer when allergenFlags == 0    -->
                <!-- ~ -->

                <!-- Section divider - hidden with allergen section -->
                <View
                    android:id="@+id/allergenDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="?attr/colorOutlineVariant"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/allergenSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:visibility="gone">

                    <!-- Compact section header - LabelMedium, not Headline6 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/allergens_title"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.05" />

                    <!--
                        Allergen icon grid.
                        Populated by AllergenIconHelper.createMultipleIconsGrid().
                    -->
                    <FrameLayout
                        android:id="@+id/allergenIconsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- ~ -->
                <!-- 2d. NUTRITION FACTS SECTION             -->
                <!-- ~ -->

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="?attr/colorOutlineVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="14dp">

                    <!-- Compact section header -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/nutrition_facts"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.05" />

                    <!-- Nutrition label block wrapper.
                         White background + thin light gray border.
                         Wraps the amount input, all label rows, and the expand button.
                         NutritionLabelManager appends its views into nutritionContainer,
                         which includes the table rows AND the "Show all nutrients" button,
                         so they all sit inside this bordered white block. -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Custom amount field with visible border -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_nutrition_block"
                            android:padding="1dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/customAmountInputLayout"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/custom_amount_default"
                                app:boxBackgroundColor="@android:color/white"
                                app:boxStrokeColor="@android:color/transparent"
                                app:boxStrokeWidthFocused="0dp"
                                app:boxCornerRadiusTopStart="7dp"
                                app:boxCornerRadiusTopEnd="7dp"
                                app:boxCornerRadiusBottomStart="7dp"
                                app:boxCornerRadiusBottomEnd="7dp">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/customAmountEditText"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:background="@android:color/white"
                                    android:inputType="numberDecimal"
                                    android:maxLines="1"
                                    android:paddingTop="8dp"
                                    android:paddingBottom="8dp" />

                            </com.google.android.material.textfield.TextInputLayout>

                        </LinearLayout>

                        <!-- Gap between amount field and nutrition table -->
                        <Space
                            android:layout_width="match_parent"
                            android:layout_height="12dp" />

                        <!-- Nutrition table with visible border.
                             1dp padding ensures the border is never covered by white children. -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@drawable/bg_nutrition_block"
                            android:padding="1dp">

                            <LinearLayout
                                android:id="@+id/nutritionContainer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="@android:color/white" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ======================================================= -->
        <!-- 3. ATTRIBUTION CARD (amber, separate)                   -->
        <!--    Separate because: different background color,        -->
        <!--    tappable (external URL), legal/meta content.         -->
        <!-- ======================================================= -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/attributionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            app:cardBackgroundColor="#FFF9C4"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeColor="#FFEA30">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/attributionSourceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    tools:text=" Open Food Facts" />

                <TextView
                    android:id="@+id/attributionLegalText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="italic"
                    tools:text="Open Food Facts" />

                <TextView
                    android:id="@+id/attributionSourceDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Open database of food products" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="end"
                    android:text="@string/label_visit_website"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>