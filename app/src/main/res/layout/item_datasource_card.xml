<?xml version="1.0" encoding="utf-8"?>
<!--
    item_datasource_card.xml
    ========================
    Reusable card rendered once per registered DataSource in SettingsActivity.
    All optional sections (credentials, local DB) start GONE and are made VISIBLE
    by DataSourceCardManager based on SettingsProvider.hasCredentials() /
    SettingsProvider.hasLocalDatabase().

    DESIGN DECISIONS v2.0
    ──────────────────────
    - "Check integrity" and "Reinitialise database" are text links (underlined,
      left-aligned) rather than Material buttons — lighter visual weight.
    - "Save" credential is also a text link for consistency.
    - Integrity result sits on its own full-width row BELOW the link so it can
      wrap naturally. breakStrategy="balanced" splits the text evenly across 2 lines,
      avoiding a second line that is much shorter than the first.
    - Status dot now has a tiny "Status" label next to it for discoverability.
    - paintFlags="8" corresponds to Paint.UNDERLINE_TEXT_FLAG — the cleanest way
      to underline a TextView without a SpannableString in XML.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface_variant_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SECTION 1 — HEADER                                                  -->
        <!-- Layout: [Source Name ·····] [Status label · dot] [Switch]          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/dsSourceName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textColor="@color/text_primary_light"
                android:textStyle="bold"
                tools:text="Ciqual" />

            <!--
                Status cluster: tiny all-caps "Status" label + coloured dot.
                The label gives first-time users context for the coloured circle.
                Kept small (9sp) so it doesn't compete with the source name.
            -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginEnd="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ds_status_label"
                    android:textSize="9sp"
                    android:textColor="@color/text_hint_light"
                    android:textAllCaps="true"
                    android:letterSpacing="0.05"
                    android:layout_marginEnd="4dp" />

                <View
                    android:id="@+id/dsStatusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/nutrition_none" />

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/dsEnableSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:contentDescription="@string/ds_enabled_label" />

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SECTION 2 — DESCRIPTION                                             -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <TextView
            android:id="@+id/dsDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/roboto_condensed"
            android:fontWeight="300"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/text_hint_light"
            android:layout_marginBottom="10dp"
            tools:text="French food composition table by ANSES" />

        <!-- Divider (always visible) -->
        <View
            android:id="@+id/dsDividerTop"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2" />

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SECTION 4 — CREDENTIALS (GONE by default)                          -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/dsCredentialSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ds_credential_section_label"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/dsCredentialInputLayout"
                style="@style/TextInputLayout.SugarDaddi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:endIconMode="clear_text">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dsCredentialInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textVisiblePassword"
                    android:singleLine="true"
                    tools:hint="API key" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/dsCredentialWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="#FF9800"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="⚠ Rate limited — register for a free key for unlimited access" />

            <!--
                "Save" as a text link — 48dp effective tap target via padding.
                paintFlags="8" = Paint.UNDERLINE_TEXT_FLAG
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dsCredentialSaveButton"
                style="@style/Button.SugarDaddi.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/ds_credential_save" />

        </LinearLayout>

        <!-- Divider after credentials -->
        <View
            android:id="@+id/dsDividerCredential"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="12dp"
            android:background="?attr/colorOutline"
            android:alpha="0.2"
            android:visibility="gone" />

        <!-- ══════════════════════════════════════════════════════════════════ -->
        <!-- SECTION 6 — LOCAL DATABASE (GONE by default)                       -->
        <!-- ══════════════════════════════════════════════════════════════════ -->

        <LinearLayout
            android:id="@+id/dsLocalDbSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ds_db_section_label"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorPrimary"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/dsDbStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_condensed"
                android:fontWeight="300"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="@color/text_secondary_light"
                android:layout_marginBottom="2dp"
                tools:text="Local database ready — offline search active" />

            <TextView
                android:id="@+id/dsDbVersionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/roboto_condensed"
                android:fontWeight="300"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_hint_light"
                android:layout_marginBottom="10dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="v2025-11-03" />

            <!-- Progress row: bar + percentage -->
            <LinearLayout
                android:id="@+id/dsDbProgressRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp"
                android:visibility="gone">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/dsDbProgressBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:trackThickness="4dp"
                    app:indicatorColor="?attr/colorPrimary"
                    app:trackColor="@color/primary_light"
                    android:indeterminate="false" />

                <TextView
                    android:id="@+id/dsDbProgressPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/text_secondary_light"
                    android:minWidth="32dp"
                    android:gravity="end"
                    tools:text="42%" />

            </LinearLayout>

            <TextView
                android:id="@+id/dsDbPhaseText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_secondary_light"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                tools:text="Importing foods... (1 200)" />

            <!--
                "Check integrity" text link.
                Full-width result TextView sits directly below so it can use
                the entire card width. breakStrategy="balanced" asks the text
                engine to split the string as evenly as possible across 2 lines,
                avoiding a near-empty second line.
            -->
            <TextView
                android:id="@+id/dsDbCheckIntegrityButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:paddingBottom="4dp"
                android:text="@string/ds_db_check_integrity"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorPrimary"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/dsDbIntegrityResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:maxLines="2"
                android:breakStrategy="balanced"
                android:hyphenationFrequency="none"
                android:visibility="gone"
                tools:text="3 484 products · 3 484 nutrition records"
                tools:visibility="visible" />

            <!--
                "Reinitialise database" text link.
                Lighter than the full-width outlined button it replaces.
            -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dsDbReinitialiseButton"
                style="@style/Button.SugarDaddi.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/ds_db_reinitialise" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>