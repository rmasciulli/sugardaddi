<?xml version="1.0" encoding="utf-8"?>
<!-- nutrition_label_header_summary.xml - Header for SUMMARY mode (2 columns) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Column headers row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:paddingLeft="6dp"
        android:paddingRight="6dp">

        <!-- Column 1: Nutrient name -->
        <TextView
            android:id="@+id/headerNutrient"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="@string/nutrition_label_nutrient_column"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@android:color/black"
            android:paddingEnd="8dp" />

        <!-- Column 2: Total -->
        <TextView
            android:id="@+id/headerTotal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/nutrition_label_summary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@android:color/black"
            android:gravity="end" />

    </LinearLayout>

    <!-- Black divider line below header -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@android:color/black"
        android:layout_marginLeft="0dp"
        android:layout_marginRight="0dp" />

</LinearLayout>