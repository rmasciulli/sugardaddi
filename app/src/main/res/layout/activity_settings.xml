<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorSurface">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                android:theme="@style/ThemeOverlay.SugarDaddi.Toolbar"
                app:title="@string/menu_settings"
                app:titleTextColor="?attr/colorOnPrimary"
                app:navigationIconTint="@android:color/white" />
        </com.google.android.material.appbar.AppBarLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ═══════════════════════════════════════ -->
                <!-- APP PREFERENCES                         -->
                <!-- ═══════════════════════════════════════ -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/surface_variant_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="20dp"
                        android:paddingBottom="8dp">

                        <!-- LANGUAGE -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/language_selector_title"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorPrimary"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />

                        <RadioGroup
                            android:id="@+id/languageRadioGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioEnglish"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/language_english"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp" />
                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioFrench"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/language_french"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp" />
                        </RadioGroup>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="?attr/colorOutline" android:alpha="0.2" />

                        <!-- THEME -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/theme_selector_title"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorPrimary"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="4dp" />

                        <RadioGroup
                            android:id="@+id/themeRadioGroup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp">
                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioSystemTheme"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_system"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp" />
                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioLightTheme"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_light"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp" />
                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioDarkTheme"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/theme_dark"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:paddingTop="10dp"
                                android:paddingBottom="10dp" />
                        </RadioGroup>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="?attr/colorOutline" android:alpha="0.2" />

                        <!-- CACHE -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/cache_management_title"
                            android:textAppearance="?attr/textAppearanceLabelLarge"
                            android:textColor="?attr/colorPrimary"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/clearCacheButton"
                            style="@style/Button.SugarDaddi.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:text="@string/menu_clear_cache" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- LOCAL DATA SOURCES header -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_data_sources_title"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:paddingStart="4dp"
                    android:layout_marginBottom="8dp" />

                <!-- ═══════════════════════════════════════ -->
                <!-- CIQUAL DATA SOURCE CARD                 -->
                <!-- ═══════════════════════════════════════ -->

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="@color/surface_variant_light">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Title row: bold name left, status dot right -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/ciqual_section_title"
                                android:textAppearance="?attr/textAppearanceBodyLarge"
                                android:textColor="@color/text_primary_light"
                                android:textStyle="bold" />

                            <!-- Status dot: coloured circle (set programmatically) -->
                            <View
                                android:id="@+id/ciqualStatusDot"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@color/nutrition_none" />

                        </LinearLayout>

                        <!-- Status text: main state description -->
                        <TextView
                            android:id="@+id/ciqualStatusText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/ciqual_status_not_ready"
                            android:fontFamily="@font/roboto_condensed"
                            android:fontWeight="300"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/text_secondary_light"
                            android:layout_marginBottom="2dp" />

                        <!-- Version metadata: same style as category in search cards -->
                        <TextView
                            android:id="@+id/ciqualVersionText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/roboto_condensed"
                            android:fontWeight="300"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/text_hint_light"
                            android:layout_marginBottom="10dp"
                            android:visibility="gone"
                            tools:text="Ciqual 2025-11-03 · 3 484 aliments"
                            tools:visibility="visible" />

                        <!-- Progress row: determinate bar + percentage label -->
                        <LinearLayout
                            android:id="@+id/ciqualProgressRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp"
                            android:visibility="gone">

                            <com.google.android.material.progressindicator.LinearProgressIndicator
                                android:id="@+id/ciqualProgressBar"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                app:trackThickness="4dp"
                                app:trackCornerRadius="2dp"
                                app:trackColor="@color/primary_light" />

                            <TextView
                                android:id="@+id/ciqualProgressPercent"
                                android:layout_width="36dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:fontFamily="@font/roboto_condensed"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="@color/text_secondary_light"
                                tools:text="42%" />

                        </LinearLayout>

                        <!-- Phase text below bar -->
                        <TextView
                            android:id="@+id/ciqualProgressText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/roboto_condensed"
                            android:fontWeight="300"
                            android:textAppearance="?attr/textAppearanceBodySmall"
                            android:textColor="@color/text_hint_light"
                            android:visibility="gone" />

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="2dp"
                            android:layout_marginBottom="4dp"
                            android:background="?attr/colorOutline"
                            android:alpha="0.2" />

                        <!--
                            Integrity row:
                            [Check] fixed left (flush, no insets) | [result] weight=1 right
                        -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!--
                                Plain TextView styled as a link button.
                                Avoids MaterialButton's hardcoded minWidth/minHeight (64dp/36dp).
                                Touch target is preserved via paddingTop/Bottom + selectableItemBackground.
                            -->
                            <TextView
                                android:id="@+id/ciqualCheckIntegrityButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="12dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:text="@string/ciqual_check_integrity"
                                android:textColor="?attr/colorPrimary"
                                android:textAppearance="?attr/textAppearanceBodyMedium"
                                android:textStyle="bold"
                                android:background="?attr/selectableItemBackground"
                                android:clickable="true"
                                android:focusable="true" />

                            <!--
                                Result text: right-aligned, auto-shrinks to 10sp before
                                wrapping to a second line (max 2 lines, then ellipsis).
                            -->
                            <TextView
                                android:id="@+id/ciqualIntegrityResult"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end|center_vertical"
                                android:textAppearance="?attr/textAppearanceBodySmall"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:autoSizeTextType="uniform"
                                android:autoSizeMinTextSize="10sp"
                                android:autoSizeMaxTextSize="12sp"
                                android:autoSizeStepGranularity="1sp"
                                android:maxLines="2"
                                android:ellipsize="end"
                                android:visibility="gone"
                                tools:text="3 484 products · 3 484 nutrition records"
                                tools:visibility="visible" />

                        </LinearLayout>

                        <!-- Reinitialise button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/ciqualImportButton"
                            style="@style/Button.SugarDaddi.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/ciqual_reimport" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="false"
        android:background="@drawable/nav_drawer_background"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_navigation_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>