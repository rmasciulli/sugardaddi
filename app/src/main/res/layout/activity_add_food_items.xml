<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_add_food_items.xml - Add Food Items to Meal

    Layout for adding food items to a meal with:
    - Meal header (name, type, time)
    - Nutrition summary (visible when items added)
    - Food items list (RecyclerView)
    - Empty state with search button
    - Save button
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorSurface"
            android:theme="@style/ThemeOverlay.Material3.Toolbar.Surface"
            app:titleTextColor="?attr/colorOnSurface"
            app:popupTheme="@style/ThemeOverlay.Material3.Light" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Meal Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Meal Type Icon + Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <!-- Meal icon (emoji) -->
                        <TextView
                            android:id="@+id/tvMealIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🌅"
                            android:textSize="32sp"
                            android:layout_marginEnd="12dp"
                            tools:ignore="HardcodedText" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Meal name -->
                            <TextView
                                android:id="@+id/tvMealName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Breakfast"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                tools:ignore="HardcodedText" />

                            <!-- Meal time -->
                            <TextView
                                android:id="@+id/tvMealTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thursday, January 22, 2026 ⏰ 08:30"
                                android:textSize="14sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Nutrition Summary (visible when items added) -->
                    <LinearLayout
                        android:id="@+id/nutritionSummaryLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="4dp"
                        android:background="?attr/colorSurfaceVariant"
                        android:gravity="center"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <!-- Calories -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalCalories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 kcal"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="?attr/colorPrimary"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <!-- Carbs -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalCarbs"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g carbs"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <!-- Protein -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalProtein"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g protein"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>

                        <!-- Fat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/tvTotalFat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0g fat"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                tools:ignore="HardcodedText" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section: Food Items -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/food_items"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="8dp" />

            <!-- Added Items List -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAddedItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:listitem="@layout/item_added_food"
                tools:itemCount="3" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/emptyStateLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="visible"
                tools:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_search_empty"
                    android:alpha="0.5"
                    android:contentDescription="@string/no_food_items_yet"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/no_food_items_yet"
                    android:textSize="16sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textAlignment="center"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <Button
                    android:id="@+id/btnSearchFood"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_food_items"
                    android:drawableStart="@drawable/ic_search"
                    android:drawablePadding="8dp"
                    style="@style/Widget.Material3.Button" />
            </LinearLayout>

            <!-- Spacer to push save button down -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="24dp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSaveMeal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/save_meal"
                android:layout_marginTop="16dp"
                android:minHeight="56dp"
                style="@style/Widget.Material3.Button" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>