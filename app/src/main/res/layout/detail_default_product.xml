<?xml version="1.0" encoding="utf-8"?>
<!--
    detail_default_product.xml - Generic fallback detail layout.

    CARD STRUCTURE (v2 - matches detail_off_product.xml pattern):
      1. Hero image (optional, no card)
      2. Main content card with internal sections:
           a. Product info: name, brand, quantity, category
           b. Score strip (optional, shown by renderer when scores available)
           c. Allergens section (optional, shown by renderer when allergenFlags != 0)
           d. Nutrition Facts section
      3. Attribution card (amber, separate, optional - hidden for user content)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 1. HERO IMAGE (optional) -->
        <ImageView
            android:id="@+id/heroImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="?attr/colorSurfaceVariant"
            android:contentDescription="@string/product_image_description"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:src="@drawable/ic_food_placeholder"
            tools:visibility="visible" />

        <!-- 2. MAIN CONTENT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- a. Product info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/productName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="3"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold"
                        tools:text="Generic Food Product" />

                    <TextView
                        android:id="@+id/brandName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorPrimary"
                        android:visibility="gone"
                        tools:text="Brand Name"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/quantityText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="100g"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/categoryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:visibility="gone"
                        tools:text="Category"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- b. Score strip (optional, hidden by default) -->
                <LinearLayout
                    android:id="@+id/scoresRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="10dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:id="@+id/nutriScoreStickerContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:layout_gravity="center_vertical"
                        android:gravity="center_vertical" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <ImageView
                        android:id="@+id/greenScoreSticker"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/content_description_green_score"
                        android:visibility="gone"
                        tools:src="@drawable/greenscore_horizontal_b" />

                    <Space
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <ImageView
                        android:id="@+id/novaGroupBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:adjustViewBounds="true"
                        android:scaleType="fitCenter"
                        android:contentDescription="@string/nova_group_content_description"
                        android:visibility="gone"
                        tools:src="@drawable/novagroup_4" />

                </LinearLayout>

                <!-- c. Allergens section (optional) -->
                <View
                    android:id="@+id/allergenDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="?attr/colorOutlineVariant"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/allergenSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/allergens_title"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.05" />

                    <FrameLayout
                        android:id="@+id/allergenIconsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <!-- d. Nutrition Facts section (always shown) -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="14dp"
                    android:background="?attr/colorOutlineVariant" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="14dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="@string/nutrition_facts"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:letterSpacing="0.05" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_nutrition_block"
                        android:padding="1dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/customAmountInputLayout"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/custom_amount_default"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="@android:color/transparent"
                            app:boxStrokeWidthFocused="0dp"
                            app:boxCornerRadiusTopStart="7dp"
                            app:boxCornerRadiusTopEnd="7dp"
                            app:boxCornerRadiusBottomStart="7dp"
                            app:boxCornerRadiusBottomEnd="7dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/customAmountEditText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:background="@android:color/white"
                                android:inputType="numberDecimal"
                                android:maxLines="1"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_nutrition_block"
                        android:padding="1dp">

                        <LinearLayout
                            android:id="@+id/nutritionContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="@android:color/white" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 3. ATTRIBUTION CARD (amber, separate, tappable) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/attributionPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:cardBackgroundColor="#FFF9C4"
            app:cardCornerRadius="12dp"
            app:cardElevation="1dp"
            app:strokeColor="#FFEA30"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/attributionSourceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceLabelMedium"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold"
                    tools:text="Source" />

                <TextView
                    android:id="@+id/attributionLegalText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="italic"
                    tools:text="Attribution text" />

                <TextView
                    android:id="@+id/attributionSourceDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    tools:text="Source description" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="end"
                    android:text="@string/label_visit_website"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorPrimary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>