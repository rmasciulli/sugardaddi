<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml - Refactored for proper RecyclerView pagination
    Main search interface with autocomplete + Navigation Drawer

    ARCHITECTURE:
    - Search card is FIXED at the top (never scrolls away)
    - RecyclerView fills remaining space and handles its own scrolling
    - Empty/Error states overlay the results area
    - NO NestedScrollView - RecyclerView manages recycling and pagination natively

    WHY NO NestedScrollView:
    NestedScrollView + RecyclerView with nestedScrollingEnabled=false disables
    view recycling, causing all items to be laid out at once. This breaks
    onBind-based pagination triggers and wastes memory with large result sets.
-->
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:openDrawer="end">

    <!-- MAIN CONTENT -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.activities.MainActivity">

        <!-- App Bar -->
        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="#EBF5FB"
                android:theme="@style/ThemeOverlay.Material3.Toolbar.Surface"
                app:titleTextColor="?attr/colorOnSurface"
                app:popupTheme="@style/ThemeOverlay.Material3.Light" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Content below app bar: fixed search card + scrollable results -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="?attr/colorSurface"
            android:contentDescription="@string/content_description_main_content"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <!-- Search bar — plain colored background, no card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#EBF5FB"
                android:contentDescription="@string/content_description_search_section"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Search Input with Autocomplete -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/searchInputLayout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/search_hint"
                        app:startIconDrawable="@drawable/ic_search"
                        app:endIconMode="clear_text"
                        app:boxBackgroundMode="filled"
                        app:boxBackgroundColor="?attr/colorSurface"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:boxStrokeWidth="0dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxStrokeColor="?attr/colorPrimary"
                        app:startIconContentDescription="@string/content_description_search_icon"
                        app:endIconContentDescription="@string/content_description_clear_search"
                        app:helperText="@string/search_placeholder"
                        app:helperTextTextColor="?attr/colorOnSurfaceVariant"
                        app:helperTextEnabled="true"
                        app:hintTextColor="?attr/colorOnSurfaceVariant">

                        <AutoCompleteTextView
                            android:id="@+id/searchEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:completionThreshold="3"
                            android:dropDownHeight="wrap_content"
                            android:imeOptions="actionSearch"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface"
                            android:importantForAccessibility="yes"
                            android:popupBackground="?attr/colorSurface"
                            android:dropDownSelector="?attr/selectableItemBackground" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Progress Indicator -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressIndicator"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        android:contentDescription="@string/content_description_loading_progress"
                        app:indicatorColor="?attr/colorPrimary"
                        app:trackColor="?attr/colorSurfaceVariant"
                        app:trackCornerRadius="2dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Results Area (fills remaining space) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <!-- RecyclerView - handles its own scrolling and view recycling -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipToPadding="false"
                    android:paddingBottom="88dp"
                    android:contentDescription="@string/content_description_search_results"
                    android:importantForAccessibility="yes"
                    tools:itemCount="3" />

                <!-- Empty State -->
                <LinearLayout
                    android:id="@+id/emptyStateView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="40dp"
                    android:visibility="gone"
                    android:focusable="true"
                    android:importantForAccessibility="yes">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="24dp"
                        android:alpha="0.7"
                        android:src="@drawable/ic_search_empty"
                        android:contentDescription="@string/content_description_empty_state_icon"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/emptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:gravity="center"
                        android:importantForAccessibility="yes"
                        android:text="@string/empty_initial_title"
                        android:textAlignment="center"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/emptyMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"
                        android:text="@string/empty_initial_message"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingExtra="4dp"
                        android:importantForAccessibility="yes" />

                </LinearLayout>

                <!-- Error State -->
                <LinearLayout
                    android:id="@+id/errorStateView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="40dp"
                    android:visibility="gone"
                    android:focusable="true"
                    android:importantForAccessibility="yes">

                    <ImageView
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="24dp"
                        android:alpha="0.7"
                        android:src="@drawable/ic_error"
                        android:contentDescription="@string/content_description_error_icon"
                        android:importantForAccessibility="no"
                        app:tint="?attr/colorError" />

                    <TextView
                        android:id="@+id/errorTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/error_network_title"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorError"
                        android:textStyle="bold"
                        android:importantForAccessibility="yes" />

                    <TextView
                        android:id="@+id/errorMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="24dp"
                        android:gravity="center"
                        android:text="@string/error_network_message"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:lineSpacingExtra="4dp"
                        android:importantForAccessibility="yes" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/tryAgainButton"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/try_again"
                        android:contentDescription="@string/content_description_try_again" />

                </LinearLayout>

            </FrameLayout>

        </LinearLayout>

        <!-- Barcode Scanner FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabScan"
            style="@style/FloatingActionButton.SugarDaddi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="bottom|end"
            android:src="@drawable/ic_barcode_scanner"
            android:contentDescription="@string/scan_product"
            app:fabSize="normal"
            app:backgroundTint="?attr/colorPrimary"
            app:tint="?attr/colorOnPrimary"
            app:elevation="6dp" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="false"
        android:background="@drawable/nav_drawer_background"
        app:headerLayout="@layout/nav_header"
        app:menu="@menu/menu_navigation_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>