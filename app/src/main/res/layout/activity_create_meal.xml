<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.SugarDaddi.Toolbar">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="@string/new_meal_title"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Header (Simplified - no close button) -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_meal_subtitle"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginBottom="24dp"/>

            <!-- Date and Time Section -->
            <TextView
                android:id="@+id/tvSelectDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_date_time"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="12dp"/>

            <!-- Date/Time Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnNow"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/button_now"
                    android:textColor="@color/button_text_normal"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:background="@drawable/selector_date_time_button"
                    android:layout_marginEnd="8dp"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <ImageButton
                    android:id="@+id/btnCalendar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/selector_date_time_button"
                    android:src="@drawable/ic_calendar_stateful"
                    android:scaleType="center"
                    android:contentDescription="@string/select_date_time"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>
            </LinearLayout>

            <!-- Display selected date/time -->
            <TextView
                android:id="@+id/tvDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuesday, November 25, 2025 | 12:28"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginBottom="24dp"
                android:layout_gravity="center_horizontal"/>

            <!-- Separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/button_border_gray"
                android:layout_marginBottom="24dp"/>

            <!-- Meal Type Section -->
            <TextView
                android:id="@+id/tvSelectMealType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_meal_type"
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:layout_marginBottom="12dp"/>

            <!-- Meal Type Grid (2x2) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignBounds"
                android:layout_marginBottom="32dp">

                <Button
                    android:id="@+id/btnBreakfast"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/meal_type_breakfast"
                    android:textColor="@color/button_text_normal"
                    android:textSize="16sp"
                    android:background="@drawable/selector_meal_type_button"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <Button
                    android:id="@+id/btnLunch"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/meal_type_lunch"
                    android:textColor="@color/button_text_normal"
                    android:textSize="16sp"
                    android:background="@drawable/selector_meal_type_button"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <Button
                    android:id="@+id/btnDinner"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/meal_type_dinner"
                    android:textColor="@color/button_text_normal"
                    android:textSize="16sp"
                    android:background="@drawable/selector_meal_type_button"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>

                <Button
                    android:id="@+id/btnSnack"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_columnWeight="1"
                    android:layout_margin="4dp"
                    android:text="@string/meal_type_snack"
                    android:textColor="@color/button_text_normal"
                    android:textSize="16sp"
                    android:background="@drawable/selector_meal_type_button"
                    android:stateListAnimator="@null"
                    android:elevation="0dp"/>
            </GridLayout>

            <!-- Create Button -->
            <Button
                android:id="@+id/btnCreateMeal"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/button_create_meal"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:background="@drawable/bg_button_create_meal"
                android:enabled="false"
                android:stateListAnimator="@null"
                android:elevation="0dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>