<?xml version="1.0" encoding="utf-8"?>
<!--
    item_search_product_default.xml
    Fallback search result card for products from sources without a dedicated
    delegate: USDA, USER, CUSTOM, IMPORTED, or null source.

    STRUCTURE:
    [Product name]                         [Source badge]
    Food product                           <- subtitle, always below title
    ─────────────────────────────────────────────────────
    [72x72 image]  Brand name
                   Category description
                   100 g

    Mirrors OFF layout exactly, minus the score stack.
    productType subtitle is in the same position as OFF and Ciqual.

    Used by: DefaultProductSearchDelegate
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ROW 1: product name + source badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/productName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Generic Food Product Name" />

            <TextView
                android:id="@+id/sourceBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="7dp"
                android:paddingVertical="2dp"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:background="@drawable/rounded_corner_8dp"
                android:backgroundTint="?attr/colorPrimaryContainer"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="USDA" />

        </LinearLayout>

        <!-- ROW 2: productType subtitle ("Food product" or "Recipe").
             Identical position and style as OFF and Ciqual layouts. -->
        <TextView
            android:id="@+id/productType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:visibility="gone"
            tools:visibility="visible"
            tools:text="Food product" />

        <!-- ROW 3: image + details (no score stack for default source) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Product image: 72x72dp -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/imageContainer"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginEnd="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <ImageView
                    android:id="@+id/productImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/colorSurface"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/product_image_description"
                    tools:src="@drawable/ic_food_placeholder" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Details column: fills remaining width -->
            <LinearLayout
                android:id="@+id/detailsColumn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Brand: Inter semi-bold, primary color -->
                <TextView
                    android:id="@+id/brandName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/inter"
                    android:fontWeight="600"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?attr/colorPrimary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="Brand Name" />

                <!-- Category: Roboto Condensed light, 2 lines, sentence case -->
                <TextView
                    android:id="@+id/categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/roboto_condensed"
                    android:fontWeight="300"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="Cereals and cereal products" />

                <!-- Serving/weight: Roboto Condensed italic, muted -->
                <TextView
                    android:id="@+id/servingInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/roboto_condensed"
                    android:textStyle="italic"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="100 g" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>