<?xml version="1.0" encoding="utf-8"?>
<!--
    item_meal_portion.xml - Expandable food portion card for MealDetailsActivity

    UPDATED DESIGN with:
    - Product thumbnail with image loading
    - Expandable nutrition details
    - Tap card to expand/collapse
    - Tap image to open ItemDetailsActivity
    - Smooth animations
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/portionCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white"
    app:rippleColor="?attr/colorPrimary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@android:color/white">

    <!-- COLLAPSED VIEW (always visible) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Product Image (clickable for ItemDetailsActivity) -->
            <ImageView
                android:id="@+id/productImage"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_corner_8dp"
                android:clipToOutline="true"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/product_image_description"
                tools:src="@drawable/ic_food_placeholder" />

            <!-- Product Info (middle section) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp">

                <!-- Product name -->

                <!-- Category (optional, uses first category from list) -->
                <TextView
                    android:id="@+id/productName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="marquee"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:marqueeRepeatLimit="marquee_forever"
                    android:singleLine="true"
                    android:maxLines="1"
                    android:scrollHorizontally="true"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="Chocolate bar, milk chocolate, with nougat" />

                <TextView
                    android:id="@+id/productCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="Chocolate products" />

                <!-- Portion -->
                <TextView
                    android:id="@+id/portionSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:layout_marginTop="4dp"
                    tools:text="40 g" />

                <!-- Nutrition preview (collapsed state) -->
                <TextView
                    android:id="@+id/nutritionPreview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="213 kcal • P: 2.3g • C: 24.2g • F: 11.6g" />
            </LinearLayout>

            <!-- Expand/collapse indicator -->
            <ImageView
                android:id="@+id/expandIndicator"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_expand_more"
                android:contentDescription="@string/expand_collapse"
                app:tint="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- EXPANDED VIEW (detailed nutrition) -->
        <LinearLayout
            android:id="@+id/expandedLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:background="?attr/colorSurfaceVariant"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Nutrition Details Grid -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Energy -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_energy_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/detailEnergy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="213 kcal" />
                </LinearLayout>

                <!-- Carbohydrates -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_carbohydrates_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/detailCarbs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="24.2 g" />
                </LinearLayout>

                <!-- Sugars (indented) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="0dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_sugars_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.8" />

                    <TextView
                        android:id="@+id/detailSugars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:alpha="0.8"
                        tools:text="5.9 g" />
                </LinearLayout>

                <!-- Proteins -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_proteins_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/detailProteins"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="2.3 g" />
                </LinearLayout>

                <!-- Fats -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_fats_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/detailFats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="11.6 g" />
                </LinearLayout>

                <!-- Fibers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/nutrient_fibers_short"
                        android:textSize="13sp"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <TextView
                        android:id="@+id/detailFibers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="normal"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        tools:text="0.4 g" />
                </LinearLayout>

            </LinearLayout>

            <!-- Tap to collapse hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_to_collapse"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:textStyle="italic"
                android:layout_marginTop="8dp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>