<?xml version="1.0" encoding="utf-8"?>
<font-family xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto">
    
    <!-- ========== REGULAR (400) ========== -->
    
    <!-- Regular Normal -->
    <font
        android:fontStyle="normal"
        android:fontWeight="400"
        android:font="@font/inter_regular"
        app:fontStyle="normal"
        app:fontWeight="400"
        app:font="@font/inter_regular" />
    
    <!-- Regular Italic -->
    <font
        android:fontStyle="italic"
        android:fontWeight="400"
        android:font="@font/inter_italic"
        app:fontStyle="italic"
        app:fontWeight="400"
        app:font="@font/inter_italic" />
    
    <!-- ========== MEDIUM (500) ========== -->
    
    <!-- Medium Normal -->
    <font
        android:fontStyle="normal"
        android:fontWeight="500"
        android:font="@font/inter_medium"
        app:fontStyle="normal"
        app:fontWeight="500"
        app:font="@font/inter_medium" />
    
    <!-- Medium Italic -->
    <font
        android:fontStyle="italic"
        android:fontWeight="500"
        android:font="@font/inter_medium_italic"
        app:fontStyle="italic"
        app:fontWeight="500"
        app:font="@font/inter_medium_italic" />
    
    <!-- ========== SEMIBOLD (600) ========== -->
    
    <!-- SemiBold Normal -->
    <font
        android:fontStyle="normal"
        android:fontWeight="600"
        android:font="@font/inter_semibold"
        app:fontStyle="normal"
        app:fontWeight="600"
        app:font="@font/inter_semibold" />
    
    <!-- SemiBold Italic -->
    <font
        android:fontStyle="italic"
        android:fontWeight="600"
        android:font="@font/inter_semibold_italic"
        app:fontStyle="italic"
        app:fontWeight="600"
        app:font="@font/inter_semibold_italic" />
    
    <!-- ========== BOLD (700) ========== -->
    
    <!-- Bold Normal -->
    <font
        android:fontStyle="normal"
        android:fontWeight="700"
        android:font="@font/inter_bold"
        app:fontStyle="normal"
        app:fontWeight="700"
        app:font="@font/inter_bold" />
    
    <!-- Bold Italic -->
    <font
        android:fontStyle="italic"
        android:fontWeight="700"
        android:font="@font/inter_bold_italic"
        app:fontStyle="italic"
        app:fontWeight="700"
        app:font="@font/inter_bold_italic" />
    
</font-family>